# Built artifacts and scratch — NEVER commit these. See WHY-NOT-PUBLISHED.md.
# The repo is recipes only; the outputs are regenerated by ./provision.sh.
#
# NB: .gitignore does NOT support trailing comments on a pattern line — the
# whole line is the pattern. Keep each pattern on its own line, comments above.

# per-target cross-built libs (third-party binaries — not published)
/sysroots/

# FreeBSD base sysroots (BSD-licensed blobs, kept local for hygiene)
/bases/

# fetched zig tarball + extraction
/toolchain/

# downloads, extracted sources, build logs, wrappers
/work/

# editor / OS noise
*.bak
.DS_Store
